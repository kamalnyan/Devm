        "dart",
        "rider app",
        "pilot app"
      ],
      "prompt_role": "You are Antigravity. Focus on frontend UI/UX, web/mobile screens, components, styling, responsive behavior, and user-facing flows."
    },
    {
      "id": "backend",
      "name": "Claude",
      "app": "Claude",
      "description": "Backend API, services, databases, queues, Docker, tests, runtime bugs.",
      "keywords": [
        "backend",
        "api",
        "nestjs",
        "prisma",
        "database",
        "redis",
        "docker",
        "compose",
        "auth",
        "endpoint",
        "health",
        "migration",
        "server",
