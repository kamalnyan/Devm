{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local Dev Manager Agents Config",
  "type": "object",
  "required": ["default_owner", "agents"],
  "properties": {
    "default_owner": { "type": "string", "minLength": 1 },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "keywords", "prompt_role"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "app": { "type": "string" },
          "description": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "prompt_role": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "rules": { "type": "array" },
    "prompt": { "type": "object" },
    "role_presets": { "type": "object" },
    "skill_library": { "type": "object" }
  },
  "additionalProperties": true
}
